{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/products/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/products",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/orders/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/health",
      "dest": "/backend/server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
