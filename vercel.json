{
  "version": 2,
  "rewrites": [
    { "source": "/api/products/:id", "destination": "/api/products?id=:id" },
    { "source": "/api/products", "destination": "/api/products" },
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
